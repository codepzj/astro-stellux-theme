<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  aria-hidden={title ? undefined : 'true'}
  role={title ? 'img' : undefined}
  set:html={`${title ? `<title>${title}</title>` : ''}<g ${common}>${paths[name]}</g>`}
/>
