---
import Icon from './Icon.astro'
import { formatRelativeTime } from '@/lib/date'
import { getPostUrl, type BlogEntryLike } from '@/lib/blog'
import { badgeClass, contentListCardClassName } from '@/lib/ui'

type Props = {
  post: BlogEntryLike
}

const { post } = Astro.props
const blogQuery = (tag?: string, category?: string) => {
  const params = new URLSearchParams()
  params.set('page', '1')
  if (tag) params.set('tag', tag)
  if (category) params.set('category', category)
  return params.toString()
}
---

<article class={`border-0 shadow-none max-sm:p-3.5 ${contentListCardClassName}`}>
  <a href={getPostUrl(post)} class="absolute inset-0 z-0 rounded-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background" aria-label={`阅读：${post.data.title}`}></a>
  <div class="relative z-10 p-0 pointer-events-none">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-stretch sm:gap-5">
      <div class="flex min-w-0 flex-1 flex-col justify-between gap-2.5 sm:gap-3">
        <div class="min-w-0">
          <h2 class="line-clamp-2 font-serif text-base font-semibold leading-snug tracking-tight text-foreground group-hover:text-primary sm:text-lg md:text-xl">
            {post.data.title}
            {post.data.isTop && (
              <span class={`${badgeClass('secondary', 'tag')} ml-1.5 inline-flex translate-y-[-0.08em] border-primary/20 bg-primary/8 align-middle text-primary dark:bg-primary/15`}>
                <Icon name="pin" class="size-3 shrink-0" />
                置顶
              </span>
            )}
          </h2>
          {post.data.description && (
            <p class="mt-1.5 line-clamp-3 text-sm leading-relaxed text-muted-foreground sm:mt-2 sm:line-clamp-2 md:line-clamp-1">
              {post.data.description}
            </p>
          )}
        </div>

        <div class="pointer-events-auto flex flex-wrap items-center gap-1.5 sm:gap-2">
          {post.data.category && (
            <a href={`/blog?${blogQuery(undefined, post.data.category)}`} class="max-w-full rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
              <span class={badgeClass('secondary', 'category', 'max-w-full cursor-pointer [&>span]:truncate')}>
                <Icon name="folder-open" class="size-3 shrink-0" />
                <span class="truncate">{post.data.category}</span>
              </span>
            </a>
          )}
          {(post.data.tags ?? []).slice(0, 2).map((tag) => (
            <a href={`/blog?${blogQuery(tag)}`} class="max-w-[min(100%,12rem)] rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
              <span class={badgeClass('outline', 'tag', 'max-w-full cursor-pointer [&>span]:truncate')}>
                <Icon name="tag" class="size-3 shrink-0" />
                <span class="truncate">{tag}</span>
              </span>
            </a>
          ))}
          <span class={badgeClass('outline', 'meta', 'w-fit shrink-0')}>
            <Icon name="calendar" class="size-3 shrink-0" />
            {formatRelativeTime(post.data.pubDate)}
          </span>
        </div>
      </div>

      <div class="relative hidden w-36 shrink-0 sm:block md:w-40">
        <div class="relative aspect-video overflow-hidden rounded-lg bg-muted/50 ring-1 ring-inset ring-border/60">
          {post.data.thumbnail ? (
            <img src={post.data.thumbnail} alt="" class="absolute inset-0 size-full object-cover transition-transform duration-300 motion-safe:group-hover:scale-[1.04]" loading="lazy" />
          ) : (
            <div class="absolute inset-0 flex items-center justify-center bg-linear-to-br from-muted/80 to-muted/40">
              <Icon name="book-open" class="size-8 text-muted-foreground/60" />
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</article>
