---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { BLOG_CONTENT_MAX_CLASS } from '@/lib/site'

type Props = {
  title: string
  kicker: string
  description: string
}

const { title, kicker, description } = Astro.props
---

<BaseLayout title={title} description={description}>
  <main class="relative min-h-[60vh] bg-background">
    <div class="relative container mx-auto px-4 py-10 md:px-6 md:py-16">
      <section class={`mx-auto w-full rounded-2xl border border-border/70 bg-muted/30 px-4 py-8 md:px-6 ${BLOG_CONTENT_MAX_CLASS}`}>
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">{kicker}</p>
        <h1 class="mt-3 font-serif text-3xl font-bold tracking-tight text-foreground">{title}</h1>
        <p class="mt-3 max-w-md text-sm leading-relaxed text-muted-foreground">{description}</p>
      </section>
    </div>
  </main>
</BaseLayout>
