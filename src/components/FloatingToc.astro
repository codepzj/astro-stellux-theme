---
import Icon from './Icon.astro'
import { buttonClass } from '@/lib/ui'

type Heading = {
  depth: number
  slug: string
  text: string
}

type Props = {
  headings: Heading[]
}

const headings = Astro.props.headings.filter((heading) => heading.depth === 2 || heading.depth === 3)
---

{headings.length > 0 && (
  <div class="pointer-events-none fixed bottom-20 right-6 z-40 flex max-w-[calc(100vw-3rem)] flex-col-reverse items-end gap-2">
    <button
      type="button"
      class={buttonClass('outline', 'icon', 'pointer-events-auto size-9 rounded-full border-border/80 bg-background/90 shadow-md backdrop-blur-sm hover:bg-background')}
      aria-expanded="false"
      aria-controls="floating-toc-panel"
      aria-label="打开文章目录"
      data-toc-toggle
    >
      <Icon name="list" class="size-4 toc-list-icon" />
      <Icon name="x" class="hidden size-4 toc-close-icon" />
    </button>
    <div
      id="floating-toc-panel"
      role="dialog"
      aria-label="文章目录"
      class="pointer-events-auto hidden max-h-[min(50vh,22rem)] w-72 origin-bottom-right overflow-y-auto overscroll-contain rounded-xl border border-border/70 bg-background/95 p-3 text-xs shadow-lg backdrop-blur-md"
      data-toc-panel
    >
      <nav aria-label="文章目录">
        <ul class="flex flex-col gap-0.5">
          {headings.map((heading) => (
            <li class={heading.depth === 3 ? 'pl-3' : ''}>
              <a href={`#${heading.slug}`} data-toc-link={heading.slug} class="block rounded-md px-1 py-1 text-[13px] leading-snug text-muted-foreground transition-colors hover:text-foreground">
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
)}

<script is:inline>
  ;(() => {
    const toggle = document.querySelector('[data-toc-toggle]')
    const panel = document.querySelector('[data-toc-panel]')
    if (!toggle || !panel) return

    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') !== 'true'
      toggle.setAttribute('aria-expanded', String(open))
      toggle.setAttribute('aria-label', open ? '关闭目录' : '打开文章目录')
      panel.classList.toggle('hidden', !open)
      toggle.querySelector('.toc-list-icon')?.classList.toggle('hidden', open)
      toggle.querySelector('.toc-close-icon')?.classList.toggle('hidden', !open)
    })

    const links = Array.from(document.querySelectorAll('[data-toc-link]'))
    const ids = links.map((link) => link.getAttribute('data-toc-link')).filter(Boolean)
    function updateActive() {
      let current = ''
      for (const id of ids) {
        const element = document.getElementById(id)
        if (element && element.getBoundingClientRect().top <= 100) current = id
      }
      links.forEach((link) => {
        const active = link.getAttribute('data-toc-link') === current
        link.classList.toggle('font-medium', active)
        link.classList.toggle('text-foreground', active)
      })
    }
    window.addEventListener('scroll', updateActive, { passive: true })
    updateActive()
  })()
</script>
