---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Icon from '@/components/Icon.astro'
import { BLOG_CONTENT_MAX_CLASS } from '@/lib/site'
import {
  getDocumentEntryRootAlias,
  getDocumentEntryRootId,
  getDocumentRootUrl,
  isDocumentRootEntry,
  isPublicDocumentEntry,
  sortDocumentRoots,
  type DocumentRootLike,
} from '@/lib/docs'
import { badgeClass, contentListCardClassName } from '@/lib/ui'
import { formatRelativeTime } from '@/lib/date'

const entries = await getCollection('docs')
const roots = sortDocumentRoots(
  entries
    .filter((entry) => isDocumentRootEntry(entry) && isPublicDocumentEntry(entry))
    .map((entry) => ({
      entry,
      id: getDocumentEntryRootId(entry),
      title: entry.data.title,
      alias: getDocumentEntryRootAlias(entry),
      description: entry.data.description,
      thumbnail: entry.data.thumbnail,
      sort: entry.data.sort,
      createdAt: entry.data.pubDate ?? entry.data.updatedDate ?? new Date(0),
      updatedAt: entry.data.updatedDate,
    }))
)
---

<BaseLayout title="文档" description="结构化知识库与公开文档，便于查阅与沉淀。">
  <main class="relative min-h-[60vh] bg-background">
    <div class="pointer-events-none absolute inset-x-0 top-0 h-48 bg-[radial-gradient(ellipse_80%_60%_at_50%_-20%,var(--color-primary)/0.06,transparent)] dark:bg-[radial-gradient(ellipse_80%_60%_at_50%_-20%,var(--color-primary)/0.12,transparent)]" aria-hidden="true"></div>
    <div class="relative container mx-auto px-4 py-10 md:px-6 md:py-16">
      <div class={`mx-auto w-full space-y-8 ${BLOG_CONTENT_MAX_CLASS}`}>
        <div class="border-b border-border/60 pb-6">
          <div class="space-y-1.5">
            <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">Library</p>
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <h1 class="font-serif text-2xl font-bold tracking-tight text-foreground md:text-3xl">
                文档
              </h1>
              <span class="inline-flex items-center gap-1.5 text-sm text-muted-foreground">
                <Icon name="file-text" class="size-3.5 opacity-70" />
                <span class="tabular-nums">{roots.length} 篇</span>
              </span>
            </div>
            <p class="max-w-md text-sm leading-relaxed text-muted-foreground">
              结构化知识库与公开文档，便于查阅与沉淀。
            </p>
          </div>
        </div>

        <div class="flex flex-col gap-3">
          {roots.map((root: DocumentRootLike & { entry: unknown }) => (
            <article class={`border-0 shadow-none max-sm:p-3.5 ${contentListCardClassName}`}>
              <a href={getDocumentRootUrl(root)} class="absolute inset-0 z-0 rounded-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background" aria-label={`阅读：${root.title}`}></a>
              <div class="pointer-events-none relative z-10 p-0">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-stretch sm:gap-5">
                  <div class="flex min-w-0 flex-1 flex-col justify-between gap-2.5 sm:gap-3">
                    <div class="min-w-0">
                      <h2 class="line-clamp-2 font-serif text-base font-semibold leading-snug tracking-tight text-foreground group-hover:text-primary sm:text-lg md:text-xl">
                        {root.title}
                      </h2>
                      {root.description && (
                        <p class="mt-1.5 line-clamp-3 text-sm leading-relaxed text-muted-foreground sm:mt-2 sm:line-clamp-2 md:line-clamp-1">
                          {root.description}
                        </p>
                      )}
                    </div>
                    <div class="flex flex-wrap items-center gap-1.5 sm:gap-2">
                      <span class={badgeClass('secondary', 'category')}>
                        <Icon name="file-text" class="size-3 shrink-0" />
                        文档
                      </span>
                      {root.createdAt.getTime() > 0 && (
                        <span class={badgeClass('outline', 'meta', 'w-fit shrink-0')}>
                          <Icon name="calendar" class="size-3 shrink-0" />
                          {formatRelativeTime(root.createdAt)}
                        </span>
                      )}
                    </div>
                  </div>

                  <div class="relative hidden w-36 shrink-0 sm:block md:w-40">
                    <div class="relative aspect-video overflow-hidden rounded-lg bg-muted/50 ring-1 ring-inset ring-border/60">
                      {root.thumbnail ? (
                        <img src={root.thumbnail} alt="" class="absolute inset-0 size-full object-cover transition-transform duration-300 motion-safe:group-hover:scale-[1.04]" loading="lazy" />
                      ) : (
                        <div class="absolute inset-0 flex items-center justify-center bg-linear-to-br from-muted/80 to-muted/40">
                          <Icon name="library-big" class="size-8 text-muted-foreground/60" />
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
