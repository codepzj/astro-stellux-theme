---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Icon from '@/components/Icon.astro'
import { SITE } from '@/lib/site'
import { buttonClass } from '@/lib/ui'

const heroTitle = '技术博客'
const description = SITE.description
---

<BaseLayout description={SITE.description} appShell={false}>
  <main class="flex flex-1">
    <section class="flex flex-1 flex-col items-center justify-center px-4 py-12 text-center md:py-16">
      <div class="mx-auto flex w-full max-w-2xl -translate-y-8 flex-col items-center md:-translate-y-12">
        <h1 class="text-balance font-serif text-5xl font-bold tracking-tight text-foreground md:text-6xl">
          {heroTitle}
        </h1>
        <p class="mt-5 max-w-xl text-balance text-lg leading-8 text-muted-foreground md:text-xl md:leading-8">
          {description}
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a href="/blog" class={buttonClass('default', 'default')}>
            查看最新文章
            <Icon name="arrow-right" class="size-4" />
          </a>
          <a href="/document" class={buttonClass('outline', 'default')}>
            浏览知识库
            <Icon name="library-big" class="size-4" />
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
