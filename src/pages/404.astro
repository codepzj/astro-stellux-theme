---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout title="页面不存在" description="你访问的页面不存在。">
  <main class="relative min-h-[60vh] bg-background">
    <div class="relative container mx-auto px-4 py-16 md:px-6">
      <section class="mx-auto max-w-3xl rounded-2xl border border-border/70 bg-muted/30 px-4 py-8 md:px-6">
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">404</p>
        <h1 class="mt-3 font-serif text-3xl font-bold tracking-tight text-foreground">页面不存在</h1>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">这条路径暂时没有内容。</p>
        <a href="/blog" class="mt-6 inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">
          返回博客
        </a>
      </section>
    </div>
  </main>
</BaseLayout>
